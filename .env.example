# ═══════════════════════════════════════════════════════════════════
# ArogyaAI BACKEND CONFIGURATION
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# GROQ API CONFIGURATION (UPGRADED FOR HIGH-CONCURRENCY)
# ─────────────────────────────────────────────────────────────────
# 
# IMPORTANT: The backend now supports multiple Groq API keys for
# high-concurrency request handling across ~50 concurrent users.
#
# Migration from Single Key → Multiple Keys:
# ┌─ Old Setup (Single Key) ──────────────────────────────────────
# │ GROQ_API_KEY=gsk_xxx...
# │ (All requests use same key, becomes bottleneck)
# └─────────────────────────────────────────────────────────────────
#
# ┌─ New Setup (Multiple Keys) ───────────────────────────────────
# │ GROQ_API_KEY=gsk_xxx...              # Legacy (single key)
# │ GROQ_API_KEY_1=gsk_xxx...            # Multi-key setup
# │ GROQ_API_KEY_2=gsk_yyy...
# │ GROQ_API_KEY_3=gsk_zzz...
# │ GROQ_API_KEY_4=gsk_aaa...
# │ GROQ_API_KEY_5=gsk_bbb...
# │ GROQ_API_KEY_6=gsk_ccc...
# │
# │ Features:
# │ - Load balancing across keys (least-busy algorithm)
# │ - Automatic health checking with 60-second cooldown
# │ - Retry on failures with different key
# │ - Redis caching (24-hour TTL)
# │ - Automatic recovery after cooldown
# └─────────────────────────────────────────────────────────────────
#
# Backward Compatibility:
# - If only GROQ_API_KEY is set: Uses legacy single-key mode
# - If GROQ_API_KEY_1+ are set: Uses new multi-key load balancing
# - System automatically detects and switches modes
#
# Environment Setup Tips:
# 1. Obtain Groq API keys from: https://console.groq.com
# 2. Each key comes with separate rate limits (9000 req/min per key)
# 3. Combine keys to increase total throughput
# 4. Recommended: Use 4-6 keys for 50 concurrent users

# Legacy single key (optional if using multi-key setup)
GROQ_API_KEY=

# New high-concurrency multi-key setup (recommended)
# Leave empty if using legacy GROQ_API_KEY above
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=

# ─────────────────────────────────────────────────────────────────
# TWILIO (WHATSAPP INTEGRATION)
# ─────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890
TWILIO_VERIFY_SERVICE_SID=

# ─────────────────────────────────────────────────────────────────
# MEM0 (LONG-TERM MEMORY)
# ─────────────────────────────────────────────────────────────────

MEM0_API_KEY=

# ─────────────────────────────────────────────────────────────────
# REDIS (SESSION MEMORY & CACHING)
# ─────────────────────────────────────────────────────────────────
# The system uses Redis for:
# - Session management
# - Response caching (24-hour TTL)
# - Distributed state management
#
# Format: redis://[password@]host:port/db
# 
# Docker Compose: redis://redis:6379/0
# Local Development: redis://localhost:6379/0
# Remote: redis://password@redis.example.com:6379/0

REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────────
# DATABASE (SQLite or PostgreSQL)
# ─────────────────────────────────────────────────────────────────
# SQLite (Development):
#   DATABASE_URL=sqlite:///./data/health_db.sqlite
#
# PostgreSQL (Production):
#   DATABASE_URL=postgresql://user:password@localhost/health_db

DATABASE_URL=sqlite:///./data/health_db.sqlite

# ─────────────────────────────────────────────────────────────────
# RAG & VECTOR STORE
# ─────────────────────────────────────────────────────────────────
# Path to FAISS vector store for medical knowledge retrieval

VECTOR_DB_PATH=./backend/rag/vector_store

# ─────────────────────────────────────────────────────────────────
# APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────

DEBUG=False

SECRET_KEY=your-super-secret-key-change-in-production

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─────────────────────────────────────────────────────────────────
# MONITORING & LOGGING
# ─────────────────────────────────────────────────────────────────
# Check system status at:
#   GET /system/api-status          - Full API key health metrics
#   GET /system/health              - Simple health check
#
# Features:
# - Monitor active requests per key
# - Track failures and cooldown status
# - View cache hit/miss rates
# - Real-time concurrent user count